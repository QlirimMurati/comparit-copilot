  {
    "fieldPath": "geburtsdatum",
    "label": "Geburtsdatum",
    "type": "date",
    "validators": [
      {
        "kind": "required"
      },
      {
        "kind": "custom",
        "message": "dateValidator"
      },
      {
        "kind": "maxDate",
        "value": "today"
      },
      {
        "kind": "minDate",
        "value": "today-70y"
      },
      {
        "kind": "minAge",
        "value": 18,
        "message": "minAgeAtContractValidator (relative to vertragsbeginn)"
      }
    ],
    "enumValues": null,
    "humanRule": "Geburtsdatum ist ein Pflichtfeld, muss ein gültiges Datum sein, darf nicht in der Zukunft liegen, höchstens 70 Jahre zurückliegen, und der Versicherte muss bei Vertragsbeginn mindestens 18 Jahre alt sein.",
    "synonyms": [
      "DOB",
      "Date of Birth",
      "GebDat",
      "birthdate",
      "Geburtstag"
    ]
  },
  {
    "fieldPath": "vertragsbeginn",
    "label": "Vertragsbeginn",
    "type": "date",
    "validators": [
      {
        "kind": "required"
      },
      {
        "kind": "custom",
        "message": "dateValidator"
      },
      {
        "kind": "minDate",
        "value": "firstOfNextMonth-3m",
