# Local development environment.
# Copy to .env and adjust if needed. .env is gitignored.

# API
PORT=3000
APP_VERSION=0.0.0
WEB_ORIGIN=http://localhost:4200

# Database (matches infra/docker-compose.yml — non-standard ports to avoid conflicts)
DATABASE_URL=postgres://postgres:postgres@localhost:55432/copilot

# Redis (Phase 3+)
REDIS_URL=redis://localhost:56379

# Auth (stub — will swap to OIDC later)
JWT_SECRET=local-dev-only-change-me
JWT_TTL=12h

# Widget basic-auth credentials (used by <copilot-widget> to POST /api/widget/reports)
WIDGET_BASIC_USER=widget
WIDGET_BASIC_PASS=local

# Bootstrap admin (created on first migration if email not present)
BOOTSTRAP_ADMIN_EMAIL=admin@comparit.de
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_NAME=Admin

# Anthropic (Phase 3+)
ANTHROPIC_API_KEY=
