# Local development environment.
# Copy to .env and adjust if needed. .env is gitignored.

# API
PORT=3000
APP_VERSION=0.0.0
WEB_ORIGIN=http://localhost:4200

# Database (matches infra/docker-compose.yml — non-standard ports to avoid conflicts)
DATABASE_URL=postgres://postgres:postgres@localhost:55432/copilot

# Redis (Phase 3+)
REDIS_URL=redis://localhost:56379

# Auth (stub — will swap to OIDC later)
JWT_SECRET=local-dev-only-change-me
JWT_TTL=12h

# Widget basic-auth credentials (used by <copilot-widget> to POST /api/widget/reports)
WIDGET_BASIC_USER=widget
WIDGET_BASIC_PASS=local

# Bootstrap admin (created on first migration if email not present)
BOOTSTRAP_ADMIN_EMAIL=admin@comparit.de
BOOTSTRAP_ADMIN_PASSWORD=admin
BOOTSTRAP_ADMIN_NAME=Admin

# Anthropic (Phase 3+)
ANTHROPIC_API_KEY=

# Voyage AI (embeddings — used by W4 dedup, W8 code index)
# Without this set, embedding jobs will fail; the dedup endpoint will
# return 503. Reports can still be submitted; embeddings are skipped.
VOYAGE_API_KEY=

# Jira (W7) — when unset, /api/jira/* endpoints return 503.
# Atlassian uses email + API token over Basic auth.
# Token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://comparit.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
# Comma-separated project keys the JQL builder is allowed to scope to.
JIRA_ALLOWED_PROJECTS=LV
# Default project + issue type for the push-to-jira flow.
JIRA_DEFAULT_PROJECT=LV
JIRA_DEFAULT_ISSUE_TYPE=Bug
# Optional: disable the hourly delta sync cron (set to "1")
# DISABLE_JIRA_SYNC_CRON=1
# Optional: override the cron pattern (default "0 * * * *" — top of every hour)
# JIRA_DELTA_CRON=0 * * * *
